DATABASE_URL=postgresql://gruppen:gruppen@localhost:5433/gruppen_drive
SESSION_SECRET=change-me-to-a-random-secret
UPLOADS_DIR=./data/uploads

# Wird beim ersten Start automatisch angelegt (nur Benutzername + Passwort)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123

# Nur für Entwicklung: Admin-Daten bei App-Start aus .env übernehmen
ADMIN_SYNC_PASSWORD=true

# Upload-Limit: max. 150 MB pro Datei (siehe lib/limits.ts)
# Rate-Limits: Login 10/15min, Upload 30/h, Passwort ändern 10/h
